{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "kite-learning-ai-proxy",
  "main": "src/index.js",
  "compatibility_date": "2026-07-18",
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
